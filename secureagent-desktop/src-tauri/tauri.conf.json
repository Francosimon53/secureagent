{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SecureAgent",
  "version": "1.0.0",
  "identifier": "com.secureagent.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "title": "SecureAgent",
        "width": 800,
        "height": 600,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Offline AI assistant with local models",
    "longDescription": "SecureAgent Desktop is an offline AI assistant that runs completely locally using Ollama for AI inference. Your data never leaves your machine.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": null,
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:secureagent.db"]
    },
    "shell": {
      "open": true
    }
  }
}
